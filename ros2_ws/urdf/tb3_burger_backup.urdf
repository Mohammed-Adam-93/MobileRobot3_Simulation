  <!-- Caster Wheel -->
    <link name="caster_yaw">
        <visual>
            <origin rpy="0 1.5707 1.5707" xyz="0 0 0"/>
            <geometry>          
                <cylinder length="0.001" radius="0.0045000000000000005"/>
            </geometry>
            <material name="blue"/>
        </visual>

        <collision>
            <origin rpy="0 1.5707 1.5707" xyz="0 0 0"/>
            <geometry>
                <cylinder length="0.001" radius="0.0045000000000000005"/>
            </geometry>
        </collision>

        <inertial>
            <origin rpy="0 1.5707 1.5707" xyz="0 0 0"/>
            <mass value="0.001"/>
            <inertia ixx="5.145833333333334e-09" ixy="0" ixz="0" iyy="5.145833333333334e-09" iyz="0" izz="1.0125000000000003e-08"/>
        </inertial>

    </link>

    <joint name="caster_yaw_joint" type="continuous">
