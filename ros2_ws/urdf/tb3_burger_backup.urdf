<?xml version="1.0"?>
<robot name="turtle_bot_3">


  <material name="black">
        <color rgba="0.0 0.0 0.0 1"/>
  </material>

  <material name="grey">
    <color rgba="0.502 0.502 0.502 1.0"/>
  </material>

  <material name="red">
    <color rgba="1.0 0.0 0.0 1"/>
  </material>

  <material name="blue">
    <color rgba="0.0 0.0 1.0 1"/>
  </material>

  <material name="green">
    <color rgba="0.0 1.0 0.0 1"/>
  </material>


<!--**** Step One ****-->


  <!-- First Plate -->
  <link name="base_link">
  </link>


  <!-- First Plate -->
  <link name="first_plate">
    <visual>
      <geometry>
        <box size="0.1375 0.1375 0.009"/>
      </geometry>
      <material name="black"/>
    </visual>

    <collision>
        <geometry>
          <box size="0.1357 0.1357 0.009"/>
        </geometry>
    </collision>
  
    <inertial>
        <mass value="0.035"/>
        <origin rpy="0 0 0" xyz="0 0 0"/>
        <inertia ixx="5.537947916666668e-05" ixy="0" ixz="0" iyy="5.537947916666668e-05" iyz="0" izz="0.00011028645833333336"/>
    </inertial>
  </link>

    <joint name="base_link_joint" type="fixed">
        <origin rpy="0 0 0" xyz="0 0 0" />
        <parent link="base_link" />
        <child link="first_plate" />
    </joint>

    <gazebo reference="first_plate">
        <material>Gazebo/Black</material>
        <turnGravityOff>false</turnGravityOff>
    </gazebo>


  <!-- Right motor -->
  <link name="right_motor">
    <visual>
      <geometry>
            <box size="0.0465 0.034 0.0285"/>
      </geometry>
      <material name="grey"/>
    </visual>

    <collision>
        <geometry>
            <box size="0.0465 0.034 0.0285"/>
        </geometry>
    </collision>
  
    <inertial>
        <mass value="0.05"/>
        <origin rpy="0 0 0" xyz="0 0 0"/>
        <inertia ixx="8.201041666666668e-06" ixy="0" ixz="0" iyy="1.239375e-05" iyz="0" izz="1.3826041666666666e-05"/>
    </inertial>
  </link>

    <joint name="right_motor_joint" type="fixed">
        <origin rpy="0 0 0" xyz="0.020 0.05175 0.0175" />
        <parent link="first_plate" />
        <child link="right_motor" />
    </joint>

    <gazebo reference="right_motor">
        <material>Gazebo/Grey</material>
        <turnGravityOff>false</turnGravityOff>
    </gazebo>

  <!-- Right Wheel axle -->
    <link name="right_axle">      
        <visual>
            <origin rpy="0 1.5707 1.5707" xyz="0 0 0"/>
            <geometry>
                <cylinder length="0.00935" radius="0.01025"/>
            </geometry>
            <material name="grey"/>
        </visual>

        <collision>
            <origin rpy="0 1.5707 1.5707" xyz="0 0 0"/>
            <geometry>
                <cylinder length="0.00935" radius="0.01025"/>
            </geometry>
        </collision>

        <inertial>
            <origin rpy="0 1.5707 1.5707" xyz="0 0 0"/>
            <mass value="0.020"/>
            <inertia ixx="6.710166666666668e-07" ixy="0" ixz="0" iyy="6.710166666666668e-07" iyz="0" izz="1.0506250000000002e-06"/>
        </inertial>

    </link>

    <joint name="right_axle_joint" type="fixed">
        <origin rpy="0 0 0" xyz="0.012 0.014675 0.001"/>
        <child link="right_axle"/>
        <parent link="right_motor"/>
    </joint>

    <gazebo reference="right_axle">
        <material>Gazebo/Grey</material>
        <turnGravityOff>false</turnGravityOff>
    </gazebo>


  <!-- Right wheel-->
    <link name="right_wheel">      
        <visual>
            <origin rpy="0 1.5707 1.5707" xyz="0 0 0"/>
            <geometry>
                <cylinder length="0.0178" radius="0.033"/>
            </geometry>
            <material name="grey"/>
        </visual>

        <collision>
            <origin rpy="0 1.5707 1.5707" xyz="0 0 0"/>
            <geometry>
                <cylinder length="0.0178" radius="0.033"/>
            </geometry>
        </collision>

        <inertial>
            <origin rpy="0 1.5707 1.5707" xyz="0 0 0"/>
            <mass value="0.025"/>
            <inertia ixx="7.466333333333334e-06" ixy="0" ixz="0" iyy="7.466333333333334e-06" iyz="0" izz="1.3612500000000002e-05"/>
        </inertial>
    </link>

    <gazebo reference="right_wheel">
        <kp>1000000000000000000000000000.0</kp>
        <kd>1000000000000000000000000000.0</kd>
        <mu1>10.0</mu1>
        <mu2>10.0</mu2>
        <material>Gazebo/Grey</material>
        <turnGravityOff>false</turnGravityOff>
    </gazebo>

    <joint name="right_wheel_joint" type="continuous">
        <origin rpy="0 0 0" xyz="0 0.013575 0"/>
        <child link="right_wheel"/>
        <parent link="right_axle"/>
        <axis rpy="0 0 0" xyz="0 1 0"/>
        <limit effort="10000" velocity="1000"/>
        <joint_properties damping="1.0" friction="1.0"/>
    </joint>




