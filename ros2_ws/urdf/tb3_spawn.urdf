<?xml version="1.0"?>
<robot name="turtle_bot_3">


  <material name="black">
        <color rgba="0.0 0.0 0.0 1"/>
  </material>

  <material name="grey">
    <color rgba="0.3 0.3 0.3 0.75"/>
  </material>

  <material name="red">
    <color rgba="1.0 0.0 0.0 1"/>
  </material>



<!--**** Step One ****-->


  <!-- First Plate -->
  <link name="base_link">
  </link>


  <!-- First Plate -->
  <link name="first_plate">
    <visual>
      <geometry>
        <box size="0.1375 0.1375 0.009"/>
      </geometry>
      <material name="black"/>
    </visual>

    <collision>
        <geometry>
          <box size="0.1357 0.1357 0.009"/>
        </geometry>
    </collision>
  
    <inertial>
        <mass value="0.035"/>
        <origin rpy="0 0 0" xyz="0 0 0"/>
        <inertia ixx="5.394517916666666e-05" ixy="0" ixz="0" iyy="5.394517916666666e-05" iyz="0" izz="0.00010741785833333331"/>
    </inertial>
  </link>

    <joint name="base_link_joint" type="fixed">
        <origin rpy="0 0 0" xyz="0 0 0" />
        <parent link="base_link" />
        <child link="first_plate" />
    </joint>

    <gazebo reference="first_plate">
        <material>Gazebo/Black</material>
    </gazebo>


 <!-- Wheel Left -->

    <link name="left_wheel">      
        <visual>
          <origin rpy="0 1.5707 1.5707" xyz="0 0 0"/>
          <geometry>
            <cylinder length="0.0178" radius="0.033"/>
          </geometry>
          <material name="grey"/>
        </visual>
  
        <collision>
          <origin rpy="0 1.5707 1.5707" xyz="0 0 0"/>
          <geometry>
            <cylinder length="0.0178" radius="0.033"/>
          </geometry>
        </collision>
  
        <inertial>
          <origin rpy="0 1.5707 1.5707" xyz="0 0 0"/>
          <mass value="0.025"/>
          <inertia ixx="7.466333333333334e-06" ixy="0" ixz="0" iyy="7.466333333333334e-06" iyz="0" izz="1.3612500000000002e-05"/>
        </inertial>
  
    </link>
  
    <gazebo reference="left_wheel">
      <kp>1000000000000000000000000000.0</kp>
      <kd>1000000000000000000000000000.0</kd>
      <mu1>10.0</mu1>
      <mu2>10.0</mu2>
      <material>Gazebo/Grey</material>
    </gazebo>
  
    <joint name="joint_left_wheel" type="continuous">
      <origin rpy="0 0 0" xyz="-0.03225 0.080 -0.010"/>
      <child link="left_wheel"/>
      <parent link="first_plate"/>
      <axis rpy="0 0 0" xyz="0 1 0"/>
      <limit effort="10000" velocity="1000"/>
      <joint_properties damping="1.0" friction="1.0"/>
    </joint>



 <!-- Wheel Right-->

 <link name="right_wheel">      
    <visual>
      <origin rpy="0 1.5707 1.5707" xyz="0 0 0"/>
      <geometry>
        <cylinder length="0.0178" radius="0.033"/>
      </geometry>
      <material name="grey"/>
    </visual>

    <collision>
      <origin rpy="0 1.5707 1.5707" xyz="0 0 0"/>
      <geometry>
        <cylinder length="0.0178" radius="0.033"/>
      </geometry>
    </collision>

    <inertial>
      <origin rpy="0 1.5707 1.5707" xyz="0 0 0"/>
      <mass value="0.025"/>
      <inertia ixx="7.466333333333334e-06" ixy="0" ixz="0" iyy="7.466333333333334e-06" iyz="0" izz="1.3612500000000002e-05"/>
    </inertial>

</link>

<gazebo reference="right_wheel">
  <kp>1000000000000000000000000000.0</kp>
  <kd>1000000000000000000000000000.0</kd>
  <mu1>10.0</mu1>
  <mu2>10.0</mu2>
  <material>Gazebo/Grey</material>
</gazebo>

<joint name="joint_right_wheel" type="continuous">
  <origin rpy="0 0 0" xyz="-0.03225 -0.080 -0.010"/>
  <child link="right_wheel"/>
  <parent link="first_plate"/>
  <axis rpy="0 0 0" xyz="0 1 0"/>
  <limit effort="10000" velocity="1000"/>
  <joint_properties damping="1.0" friction="1.0"/>
</joint>



 <!-- Caster wheel case -->

 <link name="caster_wheel_case">
    <visual>
      <geometry>
        <box size="0.030 0.018 0.008"/>
      </geometry>
      <material name="red"/>
    </visual>

    <collision>
        <geometry>
            <box size="0.030 0.018 0.008"/>
        </geometry>
    </collision>
  
    <inertial>
        <mass value="0.010"/>
        <origin rpy="0 0 0" xyz="0 0 0"/>
        <inertia ixx="3.233333333333333e-07" ixy="0" ixz="0" iyy="8.033333333333334e-07" iyz="0" izz="1.02e-06"/>
    </inertial>
  </link>

    <joint name="caster_wheel_case_joint" type="fixed">
        <origin rpy="0 0 0" xyz="0.04875 0 -0.010" />
        <parent link="first_plate" />
        <child link="caster_wheel_case" />
    </joint>

    <gazebo reference="caster_wheel_case">
        <material>Gazebo/Grey</material>
    </gazebo>




</robot>