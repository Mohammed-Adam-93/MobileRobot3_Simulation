            <geometry>
                <box size="0.03782 0.010 0.010"/>
            </geometry>
            <material name="grey"/>
        </visual>

        <collision>
            <geometry>
                <box size="0.03782 0.010 0.010"/>
            </geometry>
        </collision>

        <inertial>
            <mass value="0.005"/>
            <inertia ixx="8.33333333e-08" ixy="0" ixz="0" iyy="6.37646833e-07" iyz="0" izz="1.02000000e-06"/>
        </inertial>

    </link>

    <joint name="right_front_lidar_support_joint" type="fixed">
        <origin rpy="0 0 0" xyz="0.01819 -0.024 0.0095"/>
        <child link="right_front_lidar_support"/>
        <parent link="fourth_plate"/>
    </joint>

    <gazebo reference="right_front_lidar_support">
        <material>Gazebo/Grey</material>
        <turnGravityOff>false</turnGravityOff>
    </gazebo>

    <!-- Left rear support -->
    <link name="left_rear_lidar_support">      
        <visual>
            <geometry>
                <box size="0.010 0.03782 0.010"/>
            </geometry>
            <material name="grey"/>
        </visual>

        <collision>
            <geometry>
                <box size="0.010 0.03782 0.010"/>
            </geometry>
        </collision>

        <inertial>
            <mass value="0.005"/>
            <inertia ixx="6.37646833e-07" ixy="0" ixz="0" iyy="8.33333333e-08" iyz="0" izz="1.02000000e-06"/>
        </inertial>

    </link>

    <joint name="left_rear_lidar_support_joint" type="fixed">
        <origin rpy="0 0 0" xyz="-0.0277 0.01891 0.0095"/>
        <child link="left_rear_lidar_support"/>
        <parent link="fourth_plate"/>
    </joint>

    <gazebo reference="left_rear_lidar_support">
        <material>Gazebo/Grey</material>
        <turnGravityOff>false</turnGravityOff>
    </gazebo>


    <!-- Right rear lidar support -->
    <link name="right_rear_lidar_support">      
        <visual>
            <geometry>
                <box size="0.010 0.03782 0.010"/>
            </geometry>
            <material name="grey"/>
        </visual>

        <collision>
            <geometry>
                <box size="0.010 0.03782 0.010"/>
            </geometry>
        </collision>

        <inertial>
            <mass value="0.005"/>
            <inertia ixx="6.37646833e-07" ixy="0" ixz="0" iyy="8.33333333e-08" iyz="0" izz="1.02000000e-06"/>
        </inertial>

    </link>

    <joint name="right_rear_lidar_support_joint" type="fixed">
        <origin rpy="0 0 0" xyz="-0.0277 -0.01891 0.0095"/>
        <child link="right_rear_lidar_support"/>
        <parent link="fourth_plate"/>
    </joint>

    <gazebo reference="right_rear_lidar_support">
        <material>Gazebo/Grey</material>
        <turnGravityOff>false</turnGravityOff>
    </gazebo>


    <!-- Lidar Support -->
        <link name="lidar_support">
            <visual>
                <geometry>
                    <mesh filename="file:///home/user/ros2_ws/install/ros2_urdf_project/share/ros2_urdf_project/meshes/lds_base.dae" scale="0.001 0.001 0.001"/>
                </geometry>
                <material name="black"/>
            </visual>

            <collision>
                <geometry>
                    <box size="0.0947 0.0727 0.0257"/>
                </geometry>
            </collision>
        
            <inertial>
                <mass value="0.1"/>
                <origin rpy="0 0 0" xyz="0 0 0"/>
                <inertia ixx="4.95481667e-05" ixy="0" ixz="0" iyy="8.02381667e-05" iyz="0" izz="1.18778167e-04"/>
            </inertial>
        </link>

        <joint name="lidar_support_joint" type="fixed">
                <origin rpy="0 0 0" xyz="0 0 0.02735" />
                <parent link="fourth_plate" />
                <child link="lidar_support" />
        </joint>

        <gazebo reference="lidar_support">
                <material>Gazebo/Grey</material>
                <turnGravityOff>false</turnGravityOff>
        </gazebo>


    <!-- Lidar frame -->
        <link name="lidar_frame">
        </link>
    
        <joint name="lida_frame_joint" type="fixed">
            <origin rpy="0 0 0" xyz="0 0 0.01"/>
            <parent link="lidar_support"/>
            <child link="lidar_frame"/>
            <axis xyz="0 0 0"/>
        </joint>


    <!-- Lidar Spinner-->
    <link name="lidar_spinner">
        <visual>
            <geometry>
                <mesh filename="file:///home/user/ros2_ws/install/ros2_urdf_project/share/ros2_urdf_project/meshes/lds_top.dae" scale="0.001 0.001 0.001"/>
            </geometry>
            <material name="black"/>
        </visual>

        <collision>
            <geometry>
                <cylinder length="0.0188" radius="0.0327"/>
            </geometry>
        </collision>
    
        <inertial>
            <mass value="0.05"/>
            <origin rpy="0 0 0" xyz="0 0 0"/>
            <inertia ixx="1.48387917e-05" ixy="0" ixz="0" iyy="1.48387917e-05" iyz="0" izz="2.67322500e-05"/>
        </inertial>
    </link>

    <joint name="lidar_spinner_joint" type="continuous">
            <origin rpy="0 0 0" xyz="0 0 0.02225" />
            <parent link="lidar_support" />
            <child link="lidar_spinner" />
            <axis xyz="0 0 1"/>
            <limit effort="10.0" velocity="2.0"/>
            <dynamics friction="0.01"/>
    </joint>

    <gazebo reference="lidar_spinner">
            <material>Gazebo/Grey</material>
            <turnGravityOff>false</turnGravityOff>
    </gazebo>


  <!-- PLUGINS -->

  <!-- JOINT PUBLISHER -->
  <gazebo>
    <plugin name="turtle_bot_3_joint_state" filename="libgazebo_ros_joint_state_publisher.so">
      <ros>
          <remapping>~/out:=joint_states</remapping>
      </ros>
      <update_rate>30</update_rate>

      <joint_name>left_wheel_joint</joint_name>
      <joint_name>right_wheel_joint</joint_name>
      <joint_name>caster_yaw_joint</joint_name>
      <joint_name>caster_roll_joint</joint_name>
      <joint_name>caster_pitch_joint</joint_name>
      
    </plugin>
  </gazebo>

  <!-- Differential drive -->
  <gazebo>
    <plugin filename="libgazebo_ros_diff_drive.so" name="differential_drive_controller">

      <!-- wheels -->
      <left_joint>left_wheel_joint</left_joint>
      <right_joint>right_wheel_joint</right_joint>

      <!-- kinematics -->
      <wheel_separation>0.160</wheel_separation>
      <wheel_diameter>0.066</wheel_diameter>

      <!-- limits -->
      <max_wheel_torque>1.0</max_wheel_torque>
      <max_wheel_acceleration>2.0</max_wheel_acceleration>

      <!-- output -->
      <publish_odom>true</publish_odom>
      <publish_odom_tf>true</publish_odom_tf>

      <odometry_frame>odom</odometry_frame>
      <robot_base_frame>base_link</robot_base_frame>

    </plugin>
  </gazebo>


  <!--   imu PlugIn   -->
  <gazebo reference="imu_link">
    <sensor name="br_imu" type="imu">
      <always_on>true</always_on>
      <update_rate>100</update_rate>
      <imu>
        <angular_velocity>
          <x>
            <noise type="gaussian">
              <mean>0.0</mean>
              <stddev>2e-4</stddev>
            </noise>
          </x>
          <y>
            <noise type="gaussian">
              <mean>0.0</mean>
              <stddev>2e-4</stddev>
            </noise>
          </y>
          <z>
            <noise type="gaussian">
              <mean>0.0</mean>
              <stddev>2e-4</stddev>
            </noise>
          </z>
        </angular_velocity>
        <linear_acceleration>
          <x>
            <noise type="gaussian">
              <mean>0.0</mean>
              <stddev>1.7e-2</stddev>
            </noise>
          </x>
          <y>
            <noise type="gaussian">
              <mean>0.0</mean>
              <stddev>1.7e-2</stddev>
            </noise>
          </y>
          <z>
            <noise type="gaussian">
              <mean>0.0</mean>
              <stddev>1.7e-2</stddev>
            </noise>
          </z>
        </linear_acceleration>
      </imu>
      <plugin name="bytes_imu" filename="libgazebo_ros_imu_sensor.so">
        <ros>
          <namespace>imu</namespace>
          <remapping>~/out:=data</remapping>
        </ros>
        <initial_orientation_as_reference>false</initial_orientation_as_reference>
      </plugin>
    </sensor>
  </gazebo>

  <!--  Camera Sensor PlugIn   -->
  <gazebo reference="camera_link">
    <sensor name="camera" type="camera">
        <update_rate>30.0</update_rate>
        <always_on>1</always_on>
        <camera name="camera">
            <horizontal_fov>1.3962634</horizontal_fov>
            <image>
                <width>480</width>
                <height>360</height>
                <format>R8G8B8</format>
            </image>
            <clip>
                <!-- distance described in meters -->
                <near>0.01</near>
                <far>20</far>
            </clip>
            <distortion>
                <k1>0.0</k1>
                <k2>0.0</k2>
                <k3>0.0</k3>
                <p1>0.0</p1>
                <p2>0.0</p2>
                <center>0.5 0.5</center>
            </distortion>
        </camera>
        <plugin filename="libgazebo_ros_camera.so" name="camera_controller">
        <ros>
            <namespace>/robot1</namespace>
            <remapping>~/image_raw:=camera1/image</remapping>
            <remapping>~/camera_info:=camera1/camera_info</remapping>
        </ros>
        <camera_name>camera_low</camera_name>
        <frame_name>camera_link</frame_name>
        </plugin>
    </sensor>
</gazebo>


    <!-- Lidar PlugIn-->
  <!-- Position Config -->
  <ros2_control name="GazeboSystem" type="system">
    <hardware>
      <plugin>gazebo_ros2_control/GazeboSystem</plugin>
    </hardware>

    <joint name="lidar_support_joint">
      <command_interface name="position">
        <param name="min">-0.05</param>
        <param name="max">0.0</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>

    <joint name="lidar_spinner_joint">
      <command_interface name="velocity">
        <param name="min">0.0</param>
        <param name="max">2.0</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>

</ros2_control>


    <gazebo>
        <plugin name="gazebo_ros2_control" filename="libgazebo_ros2_control.so">
            <!-- This must match your <ros2_control> plugin type -->
            <robot_sim_type>gazebo_ros2_control/GazeboSystem</robot_sim_type>
            <parameters>$(find ros2_urdf_project)/config/lidar_spinn_controller.yaml</parameters>
            <!-- This must match your robot_state_publisher node name -->
            <robot_param_node>/robot_state_publisher_node</robot_param_node>
        </plugin>
    </gazebo>



<gazebo reference="lidar_frame">
  <sensor name="sensor_ray" type="ray">
      <pose>0 0 0 0 0 0</pose>
      <ray>
        <scan>
          <horizontal>
            <samples>200</samples>
            <resolution>1.0</resolution>
            <min_angle>-3.14</min_angle>
            <max_angle>3.14</max_angle>
          </horizontal>
        </scan>
        <range>
          <min>0.1</min>
          <max>5.0</max>
        </range>
      </ray>
      <always_on>true</always_on>
      <visualize>true</visualize>
      <update_rate>100.0</update_rate>
      <plugin name="laser" filename="libgazebo_ros_ray_sensor.so">
        <ros>
          <namespace>/turtle_bot_3</namespace>
          <remapping>~/out:=scan</remapping>
        </ros>
        <output_type>sensor_msgs/LaserScan</output_type>
      </plugin>
  </sensor>
</gazebo>


</robot>